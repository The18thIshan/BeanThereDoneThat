[sub_resource type="GDScript" id="GDScript_ao4h1"]
script/source = "extends Node2D
	
func _ready():
	Global.current_level_name = \"level_1\"
	Global.update_paths()

func _on_transition_body_entered(body) :
	if body.has_method(\"player\"):
		print(\"hi\")
		Global.transition_scene = true
		change_scene()

	
	
func change_scene() -> void:
	if Global.transition_scene == true:
		Global.transition_scene = false
		Global.current_scene = \"victory_scene\"
		get_tree().change_scene_to_file(\"res://Scenes/ui/victory_scene.tscn\")
"

